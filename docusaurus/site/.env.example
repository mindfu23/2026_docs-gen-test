# RAG-chatbot model config, read by netlify/functions/chat.ts (server-side only).
# NEVER prefix these with VITE_ — they must not be bundled into client JS.
# Set the real values in the Netlify dashboard, not in committed files.

# OpenAI-compatible endpoint. Examples:
#   vLLM (self-host):  http://localhost:8000/v1
#   Hugging Face:      https://router.huggingface.co/v1
#   Cloudflare:        https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1
LLM_BASE_URL=

# Provider token. Use "not-needed" for a local vLLM with no key.
LLM_API_KEY=

# Base model id (the LoRAs' base). Swap to Qwen/Mistral-v0.3/etc. to change models.
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Optional LoRA adapter ref. Leave EMPTY for base-only (the default until the LoRAs pass
# the content-safety screen and are flipped public). See ../shared/MODEL_LAYER.md.
#   vLLM: the --lora-modules name (e.g. american|british)
#   HF:   dedicated Inference Endpoint serving the adapter
#   CF:   uploaded BYO-LoRA id
LLM_LORA=
